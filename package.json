{
    "name": "root",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "preinstall": "npx -y only-allow pnpm",
        "build": "turbo run build",
        "build:apps": "turbo run build --filter ./apps/*",
        "build:packages": "turbo run build --filter ./packages/*",
        "build:a": "pnpm run build:apps",
        "build:p": "pnpm run build:packages",
        "dev": "turbo run dev",
        "dev:apps": "turbo run dev --filter ./apps/*",
        "dev:packages": "turbo run dev --filter ./packages/*",
        "dev:a": "pnpm run dev:apps",
        "dev:p": "pnpm run dev:packages",
        "lint": "pnpm exec biome lint",
        "test": "turbo run test",
        "test:types": "turbo run test:types",
        "test:v": "vitest --typecheck --passWithNoTests",
        "test:v:ui": "pnpm run test:v -- --ui",
        "vercel": "vercel",
        "knip": "knip"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.4",
        "@tanstack/eslint-plugin-query": "^5.91.0",
        "@tanstack/eslint-plugin-router": "^1.132.31",
        "@types/node": "^22.13.1",
        "@vitest/ui": "^3.2.4",
        "@ylfjuk/md": "^0.0.3",
        "eslint": "^9.37.0",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-react-refresh": "^0.4.23",
        "knip": "^5.63.1",
        "tsdown": "^0.15.6",
        "turbo": "^2.5.6",
        "typescript": "5.9.2",
        "typescript-eslint": "^8.46.0",
        "vercel": "^48.2.0",
        "vitest": "^3.2.4"
    },
    "packageManager": "pnpm@10.18.0",
    "engines": {
        "node": ">=22"
    }
}