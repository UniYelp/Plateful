{
    "name": "root",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "prepare": "effect-language-service patch",
        "preinstall": "npx -y only-allow pnpm",
        "build": "turbo run build",
        "build:apps": "turbo run build --filter ./apps/*",
        "build:packages": "turbo run build --filter ./packages/*",
        "build:a": "pnpm run build:apps",
        "build:p": "pnpm run build:packages",
        "dev": "turbo run dev",
        "dev:apps": "turbo run dev --filter ./apps/*",
        "dev:packages": "turbo run dev --filter ./packages/*",
        "dev:web": "turbo watch dev --filter @plateful/web",
        "dev:a": "pnpm run dev:apps",
        "dev:p": "pnpm run dev:packages",
        "db:gen": "turbo run db:gen",
        "lint": "pnpm exec biome lint",
        "test": "turbo run test",
        "test:types": "turbo run test:types",
        "test:*": "vitest --typecheck --passWithNoTests",
        "test:*:ui": "pnpm run test:* -- --ui",
        "eval": "turbo run eval",
        "eval:*:dev": "evalite watch",
        "eval:*:ui": "evalite serve",
        "shadcn:add": "turbo run shadcn:add",
        "vercel": "vercel",
        "knip": "knip"
    },
    "devDependencies": {
        "@arethetypeswrong/core": "^0.18.2",
        "@arktype/attest": "^0.56.0",
        "@biomejs/biome": "2.3.2",
        "@convex-dev/eslint-plugin": "^1.1.1",
        "@dotenvx/dotenvx": "^1.50.1",
        "@effect/language-service": "^0.65.0",
        "@effect/vitest": "^0.27.0",
        "@tanstack/eslint-plugin-query": "^5.91.2",
        "@tanstack/eslint-plugin-router": "^1.133.19",
        "@types/node": "^22.13.1",
        "@vercel/related-projects": "^1.0.1",
        "@vitest/ui": "^4.0.15",
        "@ylfjuk/md": "^0.0.3",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "evalite": "1.0.0-beta.16",
        "knip": "^5.70.0",
        "tsdown": "^0.18.1",
        "turbo": "2.7.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.47.0",
        "unplugin-unused": "^0.5.6",
        "vercel": "^50.3.0",
        "vitest": "^4.0.15"
    },
    "packageManager": "pnpm@10.29.3",
    "engines": {
        "node": ">=22"
    }
}