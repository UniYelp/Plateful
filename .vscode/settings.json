{
	"typescript.tsdk": "node_modules\\typescript\\lib",
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit"
	},
	"eslint.workingDirectories": [
		{
			"mode": "auto"
		}
	],
	"cSpell.words": ["vercel"],
	"vsicons.associations.folders": [
		{
			"extensions": ["_"],
			"icon": "private",
			"format": "svg"
		},
		{
			"extensions": ["notes"],
			"icon": "docs",
			"format": "svg"
		},
		{
			"extensions": ["mobile"],
			"icon": "client",
			"format": "svg"
		},
		{
			"extensions": ["backend"],
			"icon": "server",
			"format": "svg"
		}
	]
}
