{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "globalDependencies": [
        ".env*"
    ],
    "tasks": {
        "_transit": {
            "dependsOn": [
                "^_transit"
            ]
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "dev:p": {
            "cache": false,
            "persistent": true
        },
        "db:gen": {},
        "test": {
            "with": [
                "test:types"
            ],
            "dependsOn": [
                "_transit"
            ]
        },
        "test:types": {
            "dependsOn": [
                "_transit"
            ]
        },
        "shadcn:add": {
            "cache": false,
            "interactive": true
        },
        "@plateful/backend#dev": {
            // "with": ["clerk:webhook"],
            "cache": false,
            "persistent": true,
            "interactive": true
        },
        "@plateful/api-gateway#dev": {
            "with": [
                "@plateful/barcode-service#dev"
            ],
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                "convex/**/*"
            ],
            "cache": false,
            "persistent": true
        },
        "@plateful/web#dev": {
            "with": [
                "@plateful/backend#dev",
                "@plateful/api-gateway#dev"
            ],
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                "convex/**/*"
            ],
            "cache": false,
            "persistent": true
        },
        "@plateful/db-sys#db:gen": {
            "inputs": [
                "prisma/**/*",
                "prisma.config.ts"
            ]
        }
    }
}