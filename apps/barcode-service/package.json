{
	"name": "@plateful/barcode-service",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"@plateful/dev-src": "./src/client/index.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"exports": {
			".": "./dist/index.js",
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"dev": "dotenvx run -- tsx watch src/dev.ts",
		"dev:p": "tsdown watch",
		"build": "tsdown",
		"test": "vitest run --typecheck",
		"test:w": "vitest --typecheck"
	},
	"dependencies": {
		"@clerk/backend": "^2.15.0",
		"@hono/clerk-auth": "^3.0.3",
		"@hono/zod-validator": "^0.7.3",
		"@t3-oss/env-core": "^0.13.8",
		"@upstash/redis": "^1.35.4",
		"dotenv": "^17.2.3",
		"hono": "^4.9.9",
		"zod": "^4.1.11"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.50.1",
		"@hono/node-server": "^1.19.5",
		"tsx": "^4.7.1"
	}
}
