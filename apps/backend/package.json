{
    "name": "@plateful/backend",
    "version": "0.0.0",
    "private": "true",
    "type": "module",
    "files": [],
    "scripts": {
        "predev": "convex dev --until-success && convex dashboard",
        "dev": "convex dev",
        "logs": "convex logs",
        "setup": "convex dev --once && convex env set VALIDATE_ENV=true",
        "migrate:dev": "convex run convex/migrations.ts:runAll",
        "seed": "convex dev --once && convex run init",
        "test": "vitest run --typecheck",
        "test:w": "vitest --typecheck",
        "test:debug": "vitest --inspect-brk --typecheck --no-file-parallelism",
        "test:coverage": "vitest run --typecheck --coverage --coverage.reporter=text"
    },
    "dependencies": {
        "@clerk/backend": "catalog:",
        "@convex-dev/migrations": "^0.3.1",
        "@elysiajs/eden": "^1.4.5",
        "@hono/zod-validator": "catalog:",
        "@plateful/ingredients": "workspace:*",
        "@plateful/units": "workspace:*",
        "@plateful/utils": "workspace:*",
        "@t3-oss/env-core": "^0.13.10",
        "convex": "catalog:",
        "convex-helpers": "^0.1.108",
        "hono": "catalog:",
        "svix": "^1.76.1",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@dotenvx/dotenvx": "^1.50.1",
        "@edge-runtime/vm": "^5.0.0",
        "@plateful/types": "workspace:*",
        "convex-test": "^0.0.41",
        "vite": "^7.1.7"
    }
}