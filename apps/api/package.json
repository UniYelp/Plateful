{
	"name": "@plateful/api",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"@plateful/dev-src": "./src/index.ts",
			"default": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"exports": {
			".": "./dist/index.mjs",
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "dotenvx run -- tsx watch src/dev.ts",
		"dev:proxy": "dotenvx run -- node --experimental-strip-types scripts/local-proxy.js",
		"start": "NODE_ENV=production node dist/index.mjs",
		"test": "vitest run --typecheck --passWithNoTests",
		"test:w": "vitest --typecheck --passWithNoTests",
		"test:agent": "dotenvx run -- tsx ./tests/langfuse/evaluate.ts",
		"test:types": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/google": "catalog:",
		"@clerk/backend": "catalog:",
		"@clerk/shared": "^3.39.0",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/cron": "^1.4.1",
		"@elysiajs/node": "^1.4.5",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/server-timing": "^1.4.0",
		"@langfuse/otel": "^4.5.1",
		"@langfuse/tracing": "^4.5.1",
		"@opentelemetry/api": "catalog:",
		"@opentelemetry/sdk-node": "^0.210.0",
		"@plateful/agents": "workspace:*",
		"@plateful/http": "workspace:*",
		"@plateful/ingredients": "workspace:*",
		"@plateful/recipes": "workspace:*",
		"@plateful/time": "workspace:*",
		"@plateful/units": "workspace:*",
		"@sinclair/typebox": "^0.34.47",
		"@t3-oss/env-core": "^0.13.8",
		"@upstash/lock": "^0.2.1",
		"@upstash/query": "^0.0.2",
		"@upstash/realtime": "^1.0.0",
		"@upstash/redis": "^1.36.0",
		"ai": "catalog:",
		"croner": "^6.0.7",
		"dedent": "^1.7.0",
		"effect": "catalog:",
		"elysia": "^1.4.25",
		"elysia-clerk": "^0.13.2",
		"exact-mirror": "^0.2.6",
		"openapi-types": "^12.1.3",
		"uuid": "^13.0.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.50.1",
		"@langfuse/client": "^4.6.1",
		"@plateful/types": "workspace:*",
		"tsx": "^4.7.1",
		"vite": "^7.3.1"
	}
}
