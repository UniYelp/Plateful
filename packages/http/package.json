{
    "name": "@plateful/http",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "files": [
        "src"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "@plateful/dev-src": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "exports": {
            ".": "./dist/index.js",
            "./package.json": "./package.json"
        }
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run --typecheck --passWithNoTests",
        "test:w": "vitest --typecheck --passWithNoTests",
        "test:types": "tsc --noEmit --project tsconfig.build.json"
    },
    "dependencies": {},
    "devDependencies": {
        "@plateful/types": "workspace:*"
    }
}