{
    "name": "@plateful/agents",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "@plateful/dev-src": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./recipes": {
            "@plateful/dev-src": "./src/features/recipes/index.ts",
            "default": "./dist/recipes/index.js"
        },
        "./safety": {
            "@plateful/dev-src": "./src/features/safety/index.ts",
            "default": "./dist/safety/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "exports": {
            ".": "./dist/index.js",
            "./recipes": "./dist/recipes/index.js",
            "./safety": "./dist/safety/index.js",
            "./package.json": "./package.json"
        }
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run --typecheck --passWithNoTests",
        "test:w": "vitest --typecheck --passWithNoTests",
        "test:types": "tsc --noEmit --project tsconfig.build.json",
        "eval": "evalite",
        "eval:dev": "evalite watch",
        "eval:ui": "evalite serve"
    },
    "dependencies": {
        "@ai-sdk/google": "catalog:",
        "@opentelemetry/api": "catalog:",
        "@pinecone-database/pinecone": "^7.1.0",
        "@plateful/ingredients": "workspace:*",
        "@plateful/recipes": "workspace:*",
        "@plateful/units": "workspace:*",
        "@plateful/utils": "workspace:*",
        "ai": "catalog:",
        "dedent": "^1.7.1",
        "effect": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@plateful/types": "workspace:*"
    }
}