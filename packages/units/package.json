{
    "name": "@plateful/units",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "files": [
        "src"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "@plateful/dev-src": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./mass": {
            "@plateful/dev-src": "./src/features/mass/index.ts",
            "default": "./dist/mass.js"
        },
        "./scalar": {
            "@plateful/dev-src": "./src/features/scalar/index.ts",
            "default": "./dist/scalar.js"
        },
        "./temperature": {
            "@plateful/dev-src": "./src/features/temperature/index.ts",
            "default": "./dist/temperature.js"
        },
        "./volume": {
            "@plateful/dev-src": "./src/features/volume/index.ts",
            "default": "./dist/volume.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "exports": {
            ".": "./dist/index.js",
            "./mass": "./dist/mass.js",
            "./scalar": "./dist/scalar.js",
            "./temperature": "./dist/temperature.js",
            "./volume": "./dist/volume.js",
            "./package.json": "./package.json"
        }
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run --typecheck --passWithNoTests",
        "test:w": "vitest --typecheck --passWithNoTests",
        "test:types": "tsc --noEmit --project tsconfig.build.json"
    },
    "dependencies": {
        "@plateful/utils": "workspace:*",
        "effect": "catalog:"
    },
    "devDependencies": {
        "@plateful/types": "workspace:*"
    }
}