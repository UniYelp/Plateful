generator client {
    provider   = "prisma-client"
    output     = "../src/__generated__/prisma"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
    schemas  = ["public", "recipes"]
}

/**
 * model <Model> {
 * // id
 * // stamps
 * //
 * // columns
 * //
 * // relations ids columns
 * //
 * // relations
 * //
 * // array relations
 * //
 * // block modifiers
 * }
 */

/**
 * TODO: add dw_id & id
 * dw_id String @id @default(uuid(7)) @db.Uuid
 * id    String @default(uuid(7)) @db.Uuid
 * ...
 * @@unique([dw_id, id])
 */

model Recipe {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    name        String
    description String

    rating      Decimal?
    reviewCount Int?
    notes       String?

    tags     String[]
    keywords String[]
    images   String[]

    source_ids Int[] /// id in the .parquet file

    ingredients  RecipeIngredient[]
    instructions RecipeInstruction[]

    @@schema("recipes")
}

model RecipeIngredient {
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    amount Int
    unit   String?

    recipeId     String @db.Uuid
    ingredientId String @db.Uuid

    recipe                 Recipe                  @relation(fields: [recipeId], references: [id])
    ingredient             Ingredient              @relation(fields: [ingredientId], references: [id])
    recipeInstructionParts RecipeInstructionPart[]

    @@id([recipeId, ingredientId])
    @@schema("recipes")
}

model RecipeInstruction {
    id        String    @unique @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    step Int

    recipeId String @db.Uuid

    recipe Recipe @relation(fields: [recipeId], references: [id])

    recipeInstructionParts RecipeInstructionPart[]

    @@id([recipeId, step])
    @@schema("recipes")
}

enum RecipeInstructionPartType {
    Text
    Action
    Tool
    Temperature
    Duration
    Ingredient
    Yield

    @@schema("recipes")
}

model RecipeInstructionPart {
    id        String    @unique @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    index Int

    type  RecipeInstructionPartType
    // []
    value Json                      @db.JsonB

    recipeId      String  @db.Uuid
    instructionId String  @db.Uuid
    ingredientId  String? @db.Uuid

    instruction      RecipeInstruction @relation(fields: [instructionId], references: [id])
    ingredient       Ingredient?       @relation(fields: [ingredientId], references: [id])
    recipeIngredient RecipeIngredient? @relation(fields: [ingredientId, recipeId], references: [ingredientId, recipeId])

    @@id([instructionId, index])
    @@schema("recipes")
}

model Ingredient {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    name        String @unique
    description String

    tags   String[]
    images String[]

    recipeIngredients      RecipeIngredient[]
    recipeInstructionParts RecipeInstructionPart[]

    @@schema("recipes")
}
