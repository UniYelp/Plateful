generator client {
    provider   = "prisma-client"
    output     = "../src/__generated__/prisma"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
    schemas  = ["public", "recipes"]
}

/**
 * model <Model> {
 * // id
 * // stamps
 * //
 * // columns
 * //
 * // relations ids columns
 * //
 * // relations
 * //
 * // array relations
 * //
 * // block modifiers
 * }
 */

/**
 * TODO: add dw_id & id
 * dw_id String @id @default(uuid(7)) @db.Uuid
 * id    String @default(uuid(7)) @db.Uuid
 * ...
 * @@unique([dw_id, id])
 */

model Recipe {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    name        String
    description String?
    tags        String[]

    cookTime String? /// ISO-8601 Duration format
    prepTime String? /// ISO-8601 Duration format

    rating      Decimal?
    reviewCount Int?
    notes       String?

    keywords String[]
    images   String[]

    source_id Int? @unique /// id in the .parquet file

    ingredients  RecipeIngredient[]
    instructions RecipeInstruction[]

    @@schema("recipes")
}

model RecipeIngredient {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    value Decimal
    unit  String?
    state String?

    recipeId     String @db.Uuid
    ingredientId String @db.Uuid

    recipe     Recipe     @relation(fields: [recipeId], references: [id])
    ingredient Ingredient @relation(fields: [ingredientId], references: [id])

    recipeInstructionParts RecipeInstructionPart[]

    @@schema("recipes")
}

model RecipeInstruction {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    step  Int
    // []
    //? maybe just parts Json @db.JsonB
    parts RecipeInstructionPart[]

    recipeId String @db.Uuid

    recipe Recipe @relation(fields: [recipeId], references: [id])

    @@schema("recipes")
}

enum RecipeInstructionPartType {
    Ingredient
    Temperature
    Duration
    Action
    Tool
    Text

    @@schema("recipes")
}

model RecipeInstructionPart {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    type  RecipeInstructionPartType
    // []
    value Json                      @db.JsonB

    instructionId String  @db.Uuid
    ingredientId  String? @db.Uuid

    instruction RecipeInstruction @relation(fields: [instructionId], references: [id])
    ingredient  RecipeIngredient? @relation(fields: [ingredientId], references: [id])

    @@schema("recipes")
}

model Ingredient {
    id        String    @id @default(uuid(7)) @db.Uuid
    createdAt DateTime  @default(now()) @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @db.Timestamptz(3)
    deletedAt DateTime? @db.Timestamptz(3)

    name String

    image String?

    recipeIngredients RecipeIngredient[]

    @@schema("recipes")
}
