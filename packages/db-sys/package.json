{
    "name": "@plateful/db-sys",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "files": [
        "src"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "@plateful/dev-src": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "exports": {
            ".": "./dist/index.js",
            "./package.json": "./package.json"
        }
    },
    "scripts": {
        "build:__fix": "tsdown",
        "dev": "tsdown --watch",
        "db:gen": "prisma generate",
        "db:mig:create": "prisma migrate dev --create-only",
        "db:mig:dev": "prisma migrate dev",
        "db:mig:push": "",
        "db:seed": "prisma db seed",
        "prisma:validate": "prisma validate",
        "test": "vitest run --typecheck --passWithNoTests",
        "test:w": "vitest --typecheck --passWithNoTests",
        "test:types:__fix": "tsc --noEmit --project tsconfig.build.json"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.0.1",
        "@prisma/client": "^7.0.1"
    },
    "devDependencies": {
        "@plateful/types": "workspace:*",
        "dotenv": "^17.2.3",
        "prisma": "^7.0.1"
    }
}
