{
	"$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": ["*/_generated/server"],
								"importNamePattern": "mutation|internalMutation",
								"message": "Use functions.ts for mutation"
							}
						]
					}
				}
			},
			"suspicious": {
				"noDuplicateTestHooks": "error"
			},
			"nursery": {
				"useSortedClasses": {
					"level": "error",
					"fix": "safe",
					"options": {
						"functions": ["clsx", "cva", "cn", "twMerge"]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"formatter": {
			"enabled": false
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							":URL:",
							":BLANK_LINE:",
							[":NODE:", ":BUN:"],
							[
								":PACKAGE:",
								":PACKAGE_WITH_PROTOCOL:",
								"!@plateful/**",
								"!@backend/**"
							],
							":BLANK_LINE:",
							"@plateful/**",
							"@backend/**",
							[":ALIAS:", "&/**", "!**/*.css*"],
							":PATH:",
							":BLANK_LINE:",
							"**/*.css*",
							":BLANK_LINE:",
							"**/*.(svg|png|jpeg)"
						]
					}
				}
			}
		}
	}
}
